# Database Configuration
POSTGRES_DB=taskflow
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<CHANGE_ME_STRONG_PASSWORD>

# Application Security
SPRING_SECURITY_PASSWORD=<CHANGE_ME_STRONG_TOKEN_SECRET>

# Persistent JWT RSA Signing Keys (Base64 Encoded PKCS#8)
# Generate via: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -outform PEM -out public.pem
# Convert to single-line Base64 to insert below. If left empty, Spring Boot dynamically generates ephemeral keys on startup.
APP_RSA_PRIVATE_KEY=<CHANGE_ME_BASE64_PRIVATE_KEY>
APP_RSA_PUBLIC_KEY=<CHANGE_ME_BASE64_PUBLIC_KEY>
